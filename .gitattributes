# Auto detect text files and normalize to LF
* text=auto eol=lf

# Explicitly declare text files
*.php text eol=lf
*.vue text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.less text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.txt text eol=lf
*.sh text eol=lf
*.sql text eol=lf
*.env text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Binary files (no normalization)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
*.mp3 binary
*.mp4 binary
*.zip binary
*.gz binary
*.tar binary
*.pdf binary
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
